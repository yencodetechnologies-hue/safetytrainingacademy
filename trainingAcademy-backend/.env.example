# Copy to .env and fill in values for local development
PORT=8000
MONGO_URI=your_mongodb_connection_string

# eWAY (required for card payments)
EWAY_ENVIRONMENT=Sandbox
EWAY_API_KEY=your_eway_api_key
EWAY_API_PASSWORD=your_eway_api_password

# Optional: extra CORS origins (comma-separated)
CLIENT_ORIGIN=http://localhost:5173
